{
  "Set variable": {
    "prefix": "set",
    "body": "Set ${1:name} = ${2:value}",
    "description": "Set a variable"
  },
  "Roar": {
    "prefix": "roar",
    "body": "Roar ${1:value}",
    "description": "Print a value"
  },
  "If statement": {
    "prefix": "if",
    "body": [
      "If ${1:condition} {",
      "\t${2:statement}",
      "}"
    ],
    "description": "If statement"
  },
  "If-Else statement": {
    "prefix": "ifelse",
    "body": [
      "If ${1:condition} {",
      "\t${2:then}",
      "} Else {",
      "\t${3:else}",
      "}"
    ],
    "description": "If-Else statement"
  },
  "For loop": {
    "prefix": "for",
    "body": [
      "For ${1:i} = ${2:0} To ${3:10} {",
      "\t${4:statement}",
      "}"
    ],
    "description": "For loop"
  },
  "While loop": {
    "prefix": "while",
    "body": [
      "While ${1:condition} {",
      "\t${2:statement}",
      "}"
    ],
    "description": "While loop"
  },
  "Function definition": {
    "prefix": "func",
    "body": [
      "Func ${1:name}(${2:param}) {",
      "\t${3:statement}",
      "}"
    ],
    "description": "Define a function"
  },
  "KittyPort": {
    "prefix": "kittyport",
    "body": "KittyPort \"${1:package}\"",
    "description": "Import a package"
  },
  "Stalk_Pack": {
    "prefix": "stalk",
    "body": "Stalk_Pack \"${1:file.lnx}\"",
    "description": "Run a Lynx file"
  },
  "Hunt": {
    "prefix": "hunt",
    "body": "Hunt",
    "description": "List all variables"
  },
  "Pounce": {
    "prefix": "pounce",
    "body": "Pounce ${1:name}",
    "description": "Delete a variable"
  }
}